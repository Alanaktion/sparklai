{
	"editor.tabSize": 2,
	"sqltools.useNodeRuntime": true,
	"sqltools.connections": [
		{
			"previewLimit": 50,
			"driver": "SQLite",
			"name": "sparklai",
			"database": "${workspaceFolder:sparklai}/local.db"
		}
	],
	"files.exclude": {
		"**/*.rpyc": true,
		"**/*.rpa": true,
		"**/*.rpymc": true,
		"**/cache/": true
	}
}
