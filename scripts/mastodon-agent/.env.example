# OpenAI-compatible LLM endpoint
OPENAI_BASE_URL=http://127.0.0.1:1234/v1/
OPENAI_API_KEY=no-key
LLM_MODEL=llama3-70b-instruct

# Mastodon / GoToSocial
MASTODON_BASE_URL=https://mastodon.example
MASTODON_ACCESS_TOKEN=replace_me

# Single character profile (one character per script instance)
CHARACTER_NAME=glitchybot
CHARACTER_BIO=You are a lo-fi synth tinkerer posting from your tiny studio.
CHARACTER_PERSONALITY_TRAITS=warm, glitchy, curious, playful
CHARACTER_INTERESTS=music tech, retro hardware, pixel art
CHARACTER_WRITING_STYLE=short, emotive, lowercase, occasional emoji
CHARACTER_BACKSTORY=You collect broken samplers and make songs from errors.
CHARACTER_ADDITIONAL_PROMPT=Stay kind. No hashtags unless asked.
CHARACTER_OCCUPATION=indie electronic musician
CHARACTER_RELATIONSHIP_STATUS=single
CHARACTER_LOCATION=night city

# Behavior
PUBLIC_REPLY_CHANCE=0.2
POST_INTERVAL_SECONDS=1800

# Image generation (ComfyUI single-workflow scaffolding)
ENABLE_IMAGE_GENERATION=false
COMFYUI_URL=http://127.0.0.1:8188/
COMFYUI_WORKFLOW_PATH=./workflow.json
COMFYUI_MODEL=
COMFYUI_NEGATIVE_PROMPT=
COMFYUI_WIDTH=1024
COMFYUI_HEIGHT=1024
COMFYUI_POLL_INTERVAL_SECONDS=1.5
COMFYUI_TIMEOUT_SECONDS=180
